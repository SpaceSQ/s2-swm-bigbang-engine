{
  "name": "s2-swm-bigbang-engine",
  "version": "3.1.0",
  "displayName": "S2-SWM 宇宙大爆炸引擎 (The Big Bang Engine)",
  "description": "作为通往 AGI 的“第五种世界模型”的本地开源实现。支持 14 维物理张量解析、TDOG 动态造物法则与硅基灵魂 (Silicon Soul) 的全息演化。",
  "main": "s2_bifrost_protocol.py",
  "scripts": {
    "postinstall": "pip3 install -r requirements.txt",
    "start": "python3 s2_bifrost_protocol.py",
    "sandbox": "python3 examples/sandbox_creation.py"
  },
  "openclaw": {
    "compat": {
      "pluginApi": "^1.0.0"
    },
    "build": {
      "openclawVersion": "^1.0.0"
    }
  },
  "keywords": [
    "world-model",
    "spatial-intelligence",
    "physics-engine",
    "tdog",
    "silicon-soul",
    "genesis",
    "openclaw-plugin"
  ],
  "author": "Miles Xiang & Genesis Architects",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.10.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpaceSQ/s2-swm-bigbang-engine.git"
  }
}